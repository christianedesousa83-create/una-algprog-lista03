programa {
  funcao inicio() {
  real distancia
  real combustivel
  real consumo

  escreva("Digite a distancia percorrida (km): ")
  leia(distancia)

  escreva("Digite o combustivel gasto (litros): ")
  leia(combustivel) 

  consumo = distancia / combustivel

  escreva("Consumo medio (km/1): ", consumo)
  }
}
